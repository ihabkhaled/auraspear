{
  "name": "auraspear-soc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:debug": "cross-env NODE_OPTIONS='--inspect' next dev --turbopack",
    "build": "next build",
    "start": "cross-env NODE_ENV=production next start",
    "start:prod": "cross-env NODE_ENV=production next start",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}\" \"*.{json,md,mjs,cjs}\"",
    "typecheck": "tsc --noEmit --pretty",
    "typecheck:watch": "tsc --noEmit --pretty --watch",
    "prepare": "node .husky/install.mjs",
    "lint-staged": "lint-staged --concurrent false",
    "validate": "npm run typecheck && npm run lint:strict && npm run format:check",
    "validate:fix": "npm run lint:fix && npm run format",
    "lint:mkdir": "node -e \"require('fs').mkdirSync('eslint-reports',{recursive:true})\"",
    "lint-report-all": "npm run lint:mkdir && eslint . -f json -o eslint-reports/eslint-all-report.json",
    "lint-report-ts": "npm run lint:mkdir && eslint \"src/**/*.{ts,tsx}\" -f json -o eslint-reports/eslint-ts-report.json",
    "lint-report-js": "npm run lint:mkdir && eslint \"src/**/*.{js,jsx}\" -f json -o eslint-reports/eslint-js-report.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@serwist/next": "^9.5.6",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.7.0",
    "serwist": "^9.5.6",
    "sonner": "^2.0.7",
    "sweetalert2": "^11.26.21",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1"
  }
}
