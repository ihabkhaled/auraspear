# =============================================================================
# AuraSpear SOC — Base Environment Variables
# =============================================================================
# Shared across all environments. Overridden by .env.{development|staging|production}
# and .env.local (for secrets).
#
# Loading priority (highest wins):
#   .env.{NODE_ENV}.local  >  .env.local  >  .env.{NODE_ENV}  >  .env
# =============================================================================

# Frontend API base URL (client-side Axios calls go here, proxied to backend)
NEXT_PUBLIC_API_URL=/api

# App metadata
NEXT_PUBLIC_APP_NAME=AuraSpear SOC
