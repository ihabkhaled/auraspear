# =============================================================================
# AuraSpear SOC — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local is gitignored and will not be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend Connection
# ---------------------------------------------------------------------------
# NestJS backend API URL (server-side only, not exposed to browser)
BACKEND_API_URL=http://localhost:4000/api/v1

# Frontend API base URL (client-side Axios base URL)
NEXT_PUBLIC_API_URL=/api

# ---------------------------------------------------------------------------
# OIDC / Microsoft Entra ID (for real authentication)
# ---------------------------------------------------------------------------
# Set these to connect to your Microsoft Entra ID tenant.
# In dev mode, the backend accepts requests without auth headers and injects
# a mock user, so these are optional for local development.
NEXT_PUBLIC_OIDC_AUTHORITY=https://login.microsoftonline.com/{your-tenant-id}/v2.0
NEXT_PUBLIC_OIDC_CLIENT_ID=your-oidc-client-id
NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/callback

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# Enable Mock Service Worker (bypasses backend, uses in-browser mocks)
NEXT_PUBLIC_ENABLE_MSW=false

# ---------------------------------------------------------------------------
# App Metadata
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=AuraSpear SOC
# Options: development | staging | production
NEXT_PUBLIC_APP_ENV=development
